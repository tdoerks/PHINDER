/*
========================================================================================
    PHINDER Nextflow config file
========================================================================================
*/

params {
    // Input/output options
    input                      = 'samplesheet.csv'
    input_mode                 = 'reads'  // 'reads', 'assembly', 'sra', 'long_reads'
    outdir                     = 'results'

    // Assembly options
    assembler                  = 'spades'  // short-read isolate assembler (default)
    skip_assembly              = false

    // Long-read / hybrid options (input_mode = 'long_reads')
    // Assembler chain: Flye -> Medaka (see docs/LONG_READS_PLAN.md)
    flye_read_type             = null  // override Flye preset (default: --nano-hq nanopore / --pacbio-hifi pacbio); e.g. '--nano-raw' for older chemistry
    medaka_model               = null  // basecaller-specific model; null lets medaka auto-select

    // QC options
    skip_fastqc                = false
    skip_fastp                 = false
    skip_nanoplot              = false  // long-read QC

    // Annotation options
    skip_pharokka              = false
    skip_vibrant               = false
    skip_phanotate             = false
    skip_diamond               = false
    skip_checkv                = false

    // Database paths (Beocat defaults)
    checkv_db                  = '/fastscratch/tylerdoe/databases/checkv-db-v1.5'
    pharokka_db                = '/fastscratch/tylerdoe/databases/pharokka_db'  // Pre-install once: install_databases.py -o <dir>. Pharokka does NOT auto-download at runtime.
    prophage_db                = '/fastscratch/tylerdoe/databases/prophage_db.dmnd'

    // Resource options
    max_cpus                   = 16
    max_memory                 = '128.GB'
    max_time                   = '240.h'

    // MultiQC options
    multiqc_config             = null
    multiqc_title              = 'PHINDER Report'
}

// Container options
apptainer.enabled = true
apptainer.autoMounts = true
apptainer.pullTimeout = '60m'  // Increase from default 20m for slow networks
apptainer.cacheDir = '/fastscratch/tylerdoe/PHINDER/apptainer_cache'  // Centralized cache

// Process resource defaults
process {
    executor = 'local'

    // Default resources
    cpus = 4
    memory = 8.GB
    time = 4.h

    // Error handling
    errorStrategy = 'retry'
    maxRetries = 1

    // Process-specific resources
    withName: FASTQC {
        cpus = 2
        memory = 4.GB
    }

    withName: FASTP {
        cpus = 4
        memory = 8.GB
    }

    withName: SPADES {
        cpus = { check_max( 8, 'cpus' ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time = { check_max( 12.h * task.attempt, 'time' ) }
        errorStrategy = 'retry'
        maxRetries = 2
    }

    // ---- Long-read / hybrid assembly (input_mode = 'long_reads') ----
    withName: NANOPLOT {
        cpus = 4
        memory = 8.GB
        time = 2.h
    }

    withName: FLYE {
        cpus = { check_max( 8, 'cpus' ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time = { check_max( 12.h * task.attempt, 'time' ) }
        errorStrategy = 'retry'
        maxRetries = 2
    }

    withName: MEDAKA {
        cpus = 4
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time = 4.h
        errorStrategy = 'retry'
        maxRetries = 1
    }

    withName: QUAST {
        cpus = 2
        memory = 4.GB
    }

    withName: CHECKV {
        cpus = 4
        memory = 16.GB
        // checkv 1.0.2 utility.run_diamond() builds a malformed DIAMOND command:
        // the db path is appended with no '--db' flag and no trailing space
        // (utility.py:251) -> '...checkv_reps.dmnd--threads 4', so DIAMOND fails
        // completeness ("Missing parameter: database file (--db/-d)", surfaced as
        // "DIAMOND task failed. Program should be rerun."). Bind-mount a one-line-
        // patched utility.py over the container copy. See assets/checkv_utility.py.
        containerOptions = "--bind ${projectDir}/assets/checkv_utility.py:/usr/local/lib/python3.10/site-packages/checkv/utility.py"
    }

    withName: PHAROKKA {
        cpus = 8
        memory = 16.GB
        time = 4.h
    }

    withName: VIBRANT {
        cpus = 8
        memory = 16.GB
    }

    withName: PHANOTATE {
        cpus = 2
        memory = 4.GB
    }

    withName: DIAMOND_PROPHAGE {
        cpus = 8
        memory = 16.GB
    }

    withName: MULTIQC {
        cpus = 2
        memory = 4.GB
    }

    withName: DOWNLOAD_SRA {
        cpus = 4
        memory = 8.GB
        time = 2.h
    }

    withName: PHINDER_SUMMARY {
        cpus = 2
        memory = 4.GB
        time = 30.m
    }
}

// Profiles for different execution environments
profiles {
    local {
        executor {
            name = 'local'
            cpus = params.max_cpus
            memory = params.max_memory
        }
    }

    slurm {
        process {
            executor = 'slurm'
            queue = 'batch.q'
            clusterOptions = '--gres=killable:0'
        }

        executor {
            queueSize = 50
            submitRateLimit = '10/1min'
            pollInterval = '45 sec'
            exitReadTimeout = '120 sec'
        }
    }

    test {
        params {
            max_cpus = 2
            max_memory = 6.GB
            max_time = 1.h
        }
    }
}

// Manifest
manifest {
    name            = 'PHINDER'
    author          = 'Tyler Doerksen'
    homePage        = 'https://github.com/tdoerks/PHINDER'
    description     = 'PHage Isolate characterizatioN, Discovery & Evaluation Resource'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '1.0.0-dev'
}

// Function to ensure that resource requirements don't go beyond
// a maximum limit
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
