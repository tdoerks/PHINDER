/*
========================================================================================
    PHINDER Nextflow config file
========================================================================================
*/

params {
    // Input/output options
    input                      = 'samplesheet.csv'
    input_mode                 = 'reads'  // 'reads', 'assembly', or 'sra'
    outdir                     = 'results'

    // Assembly options
    assembler                  = 'spades'  // 'spades' (default)
    skip_assembly              = false

    // QC options
    skip_fastqc                = false
    skip_fastp                 = false

    // Annotation options
    skip_pharokka              = false
    skip_vibrant               = false
    skip_phanotate             = false
    skip_diamond               = false
    skip_checkv                = false

    // Database paths (Beocat defaults)
    checkv_db                  = '/homes/tylerdoe/databases/checkv-db-v1.5'
    pharokka_db                = null  // Auto-downloaded if not specified
    prophage_db                = '/fastscratch/tylerdoe/databases/prophage_db.dmnd'

    // Resource options
    max_cpus                   = 16
    max_memory                 = '128.GB'
    max_time                   = '240.h'

    // MultiQC options
    multiqc_config             = null
    multiqc_title              = 'PHINDER Report'
}

// Container options
apptainer.enabled = true
apptainer.autoMounts = true
apptainer.pullTimeout = '60m'  // Increase from default 20m for slow networks
apptainer.cacheDir = '/fastscratch/tylerdoe/PHINDER/apptainer_cache'  // Centralized cache

// Process resource defaults
process {
    executor = 'local'

    // Default resources
    cpus = 4
    memory = 8.GB
    time = 4.h

    // Error handling
    errorStrategy = 'retry'
    maxRetries = 1

    // Process-specific resources
    withName: FASTQC {
        cpus = 2
        memory = 4.GB
    }

    withName: FASTP {
        cpus = 4
        memory = 8.GB
    }

    withName: SPADES {
        cpus = 8
        memory = { 32.GB * task.attempt }
        time = { 8.h * task.attempt }
        errorStrategy = 'retry'
        maxRetries = 2
    }

    withName: QUAST {
        cpus = 2
        memory = 4.GB
    }

    withName: CHECKV {
        cpus = 4
        memory = 16.GB
    }

    withName: PHAROKKA {
        cpus = 8
        memory = 16.GB
        time = 4.h
    }

    withName: VIBRANT {
        cpus = 8
        memory = 16.GB
    }

    withName: PHANOTATE {
        cpus = 2
        memory = 4.GB
    }

    withName: DIAMOND_PROPHAGE {
        cpus = 8
        memory = 16.GB
    }

    withName: MULTIQC {
        cpus = 2
        memory = 4.GB
    }

    withName: DOWNLOAD_SRA {
        cpus = 4
        memory = 8.GB
        time = 2.h
    }

    withName: PHINDER_SUMMARY {
        cpus = 2
        memory = 4.GB
        time = 30.m
    }
}

// Profiles for different execution environments
profiles {
    local {
        executor {
            name = 'local'
            cpus = params.max_cpus
            memory = params.max_memory
        }
    }

    slurm {
        process {
            executor = 'slurm'
            queue = 'batch.q'
            clusterOptions = '--partition=batch.q'
        }

        executor {
            queueSize = 50
            submitRateLimit = '10/1min'
            pollInterval = '30 sec'
        }
    }

    test {
        params {
            max_cpus = 2
            max_memory = 6.GB
            max_time = 1.h
        }
    }
}

// Manifest
manifest {
    name            = 'PHINDER'
    author          = 'Tyler Doerksen'
    homePage        = 'https://github.com/tdoerks/PHINDER'
    description     = 'PHage Isolate characterizatioN, Discovery & Evaluation Resource'
    mainScript      = 'main.nf'
    nextflowVersion = '>=24.04.0'
    version         = '1.0.0-dev'
}

// Function to ensure that resource requirements don't go beyond
// a maximum limit
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}
